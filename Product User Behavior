-- ------------------------------------------------------------
--  BASE: Monthly activity log (whether a user was active)
-- ------------------------------------------------------------
user_activity AS (
    SELECT * FROM (VALUES
        -- (user_id, activity_month, sessions, features_used)
        -- Jan cohort
        (1001,'2024-01'::DATE,12,4),(1001,'2024-02'::DATE,10,5),(1001,'2024-03'::DATE,8,5),
        (1001,'2024-04'::DATE,9,6),(1001,'2024-05'::DATE,7,6),(1001,'2024-06'::DATE,6,6),
        (1002,'2024-01'::DATE,5,1),(1002,'2024-02'::DATE,3,1),(1002,'2024-03'::DATE,0,0),
        (1003,'2024-01'::DATE,18,6),(1003,'2024-02'::DATE,15,7),(1003,'2024-03'::DATE,14,7),
        (1003,'2024-04'::DATE,12,8),(1003,'2024-05'::DATE,11,8),(1003,'2024-06'::DATE,10,8),
        (1004,'2024-01'::DATE,4,1),(1004,'2024-02'::DATE,2,1),(1004,'2024-03'::DATE,1,1),
        (1004,'2024-04'::DATE,0,0),
        (1005,'2024-01'::DATE,14,5),(1005,'2024-02'::DATE,12,5),(1005,'2024-03'::DATE,11,6),
        (1005,'2024-04'::DATE,10,6),(1005,'2024-05'::DATE,9,7),(1005,'2024-06'::DATE,8,7),
