-- ------------------------------------------------------------
--  BASE: First-value event (e.g. first meaningful action taken)
-- ------------------------------------------------------------
first_value_events AS (
    SELECT * FROM (VALUES
        -- (user_id, first_value_date)
        (1001, '2024-01-07'::DATE),
        (1003, '2024-01-19'::DATE),
        (1005, '2024-01-30'::DATE),
        (1007, '2024-02-11'::DATE),
        (1009, '2024-02-22'::DATE),
        (1011, '2024-03-04'::DATE),
        (1013, '2024-03-16'::DATE),
        (1015, '2024-03-27'::DATE),
        (1017, '2024-04-09'::DATE),
        (1019, '2024-04-20'::DATE)
        -- Free users without a first-value event are excluded (never activated)
    ) AS t(user_id, first_value_date)
),


-- =============================================================
--  STEP 1 — ASSIGN COHORT MONTH TO EACH USER
-- =============================================================
user_cohorts AS (
    SELECT
        u.user_id,
        u.plan,
        u.acquisition_channel,
        -- Truncate signup date to first day of month = cohort
        DATE_TRUNC('month', u.signup_date)::DATE                    AS cohort_month
    FROM users u
),


-- =============================================================
--  STEP 2 — CALCULATE MONTHS SINCE SIGNUP FOR EACH ACTIVITY ROW
-- =============================================================
cohort_activity AS (
    SELECT
        uc.cohort_month,
        uc.user_id,
        uc.plan,
        ua.activity_month,
        ua.sessions,
        ua.features_used,
        -- Month index: 0 = signup month, 1 = month after, etc.
        (EXTRACT(YEAR  FROM ua.activity_month) - EXTRACT(YEAR  FROM uc.cohort_month)) * 12
        + (EXTRACT(MONTH FROM ua.activity_month) - EXTRACT(MONTH FROM uc.cohort_month))
            AS month_index,
        -- Active = had at least 1 session
        CASE WHEN ua.sessions > 0 THEN 1 ELSE 0 END                AS is_active
    FROM user_cohorts uc
    JOIN user_activity ua ON uc.user_id = ua.user_id
),


-- =============================================================
--  STEP 3 — COHORT SIZE (users active in M0)
-- =============================================================
cohort_sizes AS (
    SELECT
        cohort_month,
        COUNT(DISTINCT user_id)                                     AS cohort_size
    FROM cohort_activity
    WHERE month_index = 0
    GROUP BY cohort_month
),


-- =============================================================
--  STEP 4 — RETENTION TABLE
--  Shows how many users from each cohort were still active
--  at each month index (M0–M5)
-- =============================================================
retention_table AS (
    SELECT
        ca.cohort_month,
        cs.cohort_size,
        ca.month_index,
        COUNT(DISTINCT CASE WHEN ca.is_active = 1 THEN ca.user_id END)
                                                                    AS active_users,
        ROUND(
            COUNT(DISTINCT CASE WHEN ca.is_active = 1 THEN ca.user_id END)::NUMERIC
            / cs.cohort_size * 100, 1
        )                                                           AS retention_pct
    FROM cohort_activity ca
    JOIN cohort_sizes cs ON ca.cohort_month = cs.cohort_month
    WHERE ca.month_index BETWEEN 0 AND 5
    GROUP BY ca.cohort_month, cs.cohort_size, ca.month_index
),


-- =============================================================
--  STEP 5 — CHURN BY COHORT
--  A user is "churned" if they had activity then went to 0 sessions
-- =============================================================
churned_users AS (
    SELECT DISTINCT
        ca.cohort_month,
        ca.user_id
    FROM cohort_activity ca
    WHERE ca.is_active = 0
      AND ca.month_index > 0
      -- Had been active before
      AND EXISTS (
          SELECT 1 FROM cohort_activity ca2
          WHERE ca2.user_id = ca.user_id
            AND ca2.is_active = 1
            AND ca2.month_index < ca.month_index
      )
),

churn_by_cohort AS (
    SELECT
        cs.cohort_month,
        cs.cohort_size,
        COUNT(DISTINCT cu.user_id)                                 AS churned_users,
        ROUND(
            COUNT(DISTINCT cu.user_id)::NUMERIC / cs.cohort_size * 100, 1
        )                                                          AS cohort_churn_pct
    FROM cohort_sizes cs
    LEFT JOIN churned_users cu ON cs.cohort_month = cu.cohort_month
    GROUP BY cs.cohort_month, cs.cohort_size
),


-- =============================================================
--  STEP 6 — AVG ENGAGEMENT BY COHORT & PLAN
-- =============================================================
cohort_engagement AS (
    SELECT
        uc.cohort_month,
        uc.plan,
        ROUND(AVG(ua.sessions), 1)                                 AS avg_sessions_per_month,
        ROUND(AVG(ua.features_used), 1)                            AS avg_features_adopted,
        COUNT(DISTINCT uc.user_id)                                 AS users
    FROM user_cohorts uc
    JOIN user_activity ua ON uc.user_id = ua.user_id
    WHERE ua.sessions > 0
    GROUP BY uc.cohort_month, uc.plan
),


-- =============================================================
--  STEP 7 — TIME TO FIRST VALUE (TTFV)
--  Days between signup and first meaningful product action
-- =============================================================
ttfv AS (
    SELECT
        uc.cohort_month,
        uc.plan,
        COUNT(fv.user_id)                                          AS activated_users,
        ROUND(AVG(fv.first_value_date - u.signup_date), 1)        AS avg_days_to_first_value,
        MIN(fv.first_value_date - u.signup_date)                   AS fastest_ttfv_days,
        MAX(fv.first_value_date - u.signup_date)                   AS slowest_ttfv_days
    FROM user_cohorts uc
    JOIN users u ON uc.user_id = u.user_id
    LEFT JOIN first_value_events fv ON uc.user_id = fv.user_id
    GROUP BY uc.cohort_month, uc.plan
)


-- =============================================================
--  FINAL OUTPUTS
-- =============================================================

-- Retention Table (pivot-friendly: one row per cohort × month)
SELECT
    cohort_month,
    cohort_size,
    month_index,
    active_users,
    retention_pct
FROM retention_table
ORDER BY cohort_month, month_index;

