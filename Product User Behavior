        (1008,'2024-02'::DATE,3,1),(1008,'2024-03'::DATE,2,1),(1008,'2024-04'::DATE,0,0),
        (1009,'2024-02'::DATE,11,4),(1009,'2024-03'::DATE,10,4),(1009,'2024-04'::DATE,9,5),
        (1009,'2024-05'::DATE,8,5),(1009,'2024-06'::DATE,7,5),
        (1010,'2024-02'::DATE,5,2),(1010,'2024-03'::DATE,3,2),(1010,'2024-04'::DATE,1,1),
        (1010,'2024-05'::DATE,0,0),
        -- Mar cohort
        (1011,'2024-03'::DATE,16,5),(1011,'2024-04'::DATE,14,6),(1011,'2024-05'::DATE,13,6),
        (1011,'2024-06'::DATE,12,7),
        (1012,'2024-03'::DATE,4,1),(1012,'2024-04'::DATE,2,1),(1012,'2024-05'::DATE,0,0),
        (1013,'2024-03'::DATE,13,5),(1013,'2024-04'::DATE,12,5),(1013,'2024-05'::DATE,11,6),
        (1013,'2024-06'::DATE,10,6),
        (1014,'2024-03'::DATE,3,1),(1014,'2024-04'::DATE,0,0),
