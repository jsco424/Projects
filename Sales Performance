-- =============================================================
--  SECTION 1 — YEAR-OVER-YEAR (YoY) GROWTH
--  Compares same calendar month across years.
--  Revenue growth % = (current - prior) / prior * 100
-- =============================================================

yoy_base AS (
    SELECT
        period,
        EXTRACT(YEAR  FROM period)::INT AS yr,
        EXTRACT(MONTH FROM period)::INT AS mo,
        revenue
    FROM monthly_revenue
),

yoy_growth AS (
    SELECT
        curr.period,
        curr.yr                                                         AS current_year,
        curr.mo                                                         AS month_num,
        TO_CHAR(curr.period, 'Mon')                                     AS month_name,
        curr.revenue                                                    AS current_revenue,
        prev.revenue                                                    AS prior_year_revenue,
        curr.revenue - prev.revenue                                     AS yoy_revenue_delta,
        ROUND(
            (curr.revenue - prev.revenue)::NUMERIC / prev.revenue * 100, 2
        )                                                               AS yoy_growth_pct
    FROM yoy_base curr
    JOIN yoy_base prev
        ON  curr.mo = prev.mo
        AND curr.yr = prev.yr + 1
    ORDER BY curr.period
),


-- =============================================================
--  SECTION 2 — MONTH-OVER-MONTH (MoM) GROWTH
--  Uses LAG() to pull the immediately preceding month.
-- =============================================================

mom_growth AS (
    SELECT
        period,
        TO_CHAR(period, 'YYYY-Mon')                                     AS period_label,
        revenue                                                         AS current_revenue,
        LAG(revenue) OVER (ORDER BY period)                             AS prior_month_revenue,
        revenue - LAG(revenue) OVER (ORDER BY period)                   AS mom_revenue_delta,
        ROUND(
            (revenue - LAG(revenue) OVER (ORDER BY period))::NUMERIC
            / NULLIF(LAG(revenue) OVER (ORDER BY period), 0) * 100, 2
        )                                                               AS mom_growth_pct,
        new_accounts,
        expansions,
        churned_arr
    FROM monthly_revenue
    ORDER BY period
),


-- =============================================================
--  SECTION 3 — QUARTER-OVER-QUARTER (QoQ) GROWTH
--  Aggregates monthly revenue into quarters first, then compares.
-- =============================================================

quarterly_revenue AS (
    SELECT
        EXTRACT(YEAR    FROM period)::INT                               AS yr,
        EXTRACT(QUARTER FROM period)::INT                               AS qtr,
        CONCAT('Q', EXTRACT(QUARTER FROM period)::INT,
               '-', EXTRACT(YEAR FROM period)::INT)                    AS quarter_label,
        SUM(revenue)                                                    AS quarterly_revenue,
        SUM(new_accounts)                                               AS quarterly_new_accounts,
        SUM(churned_arr)                                                AS quarterly_churned_arr
    FROM monthly_revenue
    GROUP BY 1, 2, 3
),

qoq_growth AS (
    SELECT
        curr.quarter_label                                              AS current_quarter,
        curr.quarterly_revenue                                          AS current_revenue,
        prev.quarterly_revenue                                          AS prior_quarter_revenue,
        curr.quarterly_revenue - prev.quarterly_revenue                 AS qoq_revenue_delta,
        ROUND(
            (curr.quarterly_revenue - prev.quarterly_revenue)::NUMERIC
            / NULLIF(prev.quarterly_revenue, 0) * 100, 2
        )                                                               AS qoq_growth_pct,
        curr.quarterly_new_accounts,
        curr.quarterly_churned_arr
    FROM quarterly_revenue curr
    JOIN quarterly_revenue prev
        ON  (curr.yr = prev.yr     AND curr.qtr = prev.qtr + 1)
         OR (curr.yr = prev.yr + 1 AND curr.qtr = 1 AND prev.qtr = 4)
    ORDER BY curr.yr, curr.qtr
),


-- =============================================================
--  SECTION 4 — CHURN RATE
--  Monthly churn rate = churned ARR / total ARR at period start
--  Annualized churn = monthly churn * 12
-- =============================================================

churn_metrics AS (
    SELECT
        period,
        TO_CHAR(period, 'YYYY-Mon')                                     AS period_label,
        revenue                                                         AS beginning_arr,
        churned_arr,
        ROUND(churned_arr::NUMERIC / NULLIF(revenue, 0) * 100, 2)       AS monthly_churn_rate_pct,
        ROUND(churned_arr::NUMERIC / NULLIF(revenue, 0) * 100 * 12, 2)  AS annualized_churn_rate_pct,
        -- Net Revenue Retention: (revenue + expansions - churn) / revenue
        ROUND(
            (revenue + expansions - churned_arr)::NUMERIC
            / NULLIF(revenue, 0) * 100, 2
        )                                                               AS net_revenue_retention_pct
    FROM monthly_revenue
    ORDER BY period
),


-- =============================================================
--  SECTION 5 — TOP INDUSTRIES BY REVENUE
--  Ranks industries by total active ARR and account count.
-- =============================================================

industry_metrics AS (
    SELECT
        industry,
        COUNT(*)                                                        AS total_accounts,
        SUM(CASE WHEN status = 'active'  THEN 1 ELSE 0 END)            AS active_accounts,
        SUM(CASE WHEN status = 'churned' THEN 1 ELSE 0 END)            AS churned_accounts,
        SUM(arr)                                                        AS total_arr,
        SUM(CASE WHEN status = 'active' THEN arr ELSE 0 END)           AS active_arr,
        ROUND(AVG(arr), 0)                                              AS avg_arr_per_account,
        ROUND(
            SUM(CASE WHEN status = 'churned' THEN 1 ELSE 0 END)::NUMERIC
            / COUNT(*) * 100, 1
        )                                                               AS industry_churn_rate_pct,
        RANK() OVER (ORDER BY SUM(CASE WHEN status='active' THEN arr ELSE 0 END) DESC) AS revenue_rank
    FROM accounts
    GROUP BY industry
    ORDER BY active_arr DESC
),


-- =============================================================
--  SECTION 6 — MARKETING FUNNEL DISTRIBUTION
--  Stage-by-stage counts + conversion rates between each stage.
-- =============================================================

funnel_metrics AS (
    SELECT
        period,
        TO_CHAR(period, 'YYYY-Mon')                                     AS period_label,
        mql,
        sal,
        sql,
        opportunity                                                     AS oppty,
        closed_won,
        closed_lost,
        closed_won + closed_lost                                        AS total_decisions,

        -- Stage-to-stage conversion rates
        ROUND(sal::NUMERIC        / NULLIF(mql, 0)         * 100, 1)   AS mql_to_sal_pct,
        ROUND(sql::NUMERIC        / NULLIF(sal, 0)         * 100, 1)   AS sal_to_sql_pct,
        ROUND(opportunity::NUMERIC / NULLIF(sql, 0)        * 100, 1)   AS sql_to_oppty_pct,
        ROUND(closed_won::NUMERIC / NULLIF(opportunity, 0) * 100, 1)   AS oppty_to_won_pct,

        -- Overall funnel win rate: MQL → Closed Won
        ROUND(closed_won::NUMERIC / NULLIF(mql, 0)         * 100, 2)   AS overall_win_rate_pct,

        -- Win rate among decisions made
        ROUND(
            closed_won::NUMERIC / NULLIF(closed_won + closed_lost, 0) * 100, 1
        )                                                               AS decision_win_rate_pct
    FROM funnel_events
    ORDER BY period
),


-- =============================================================
--  SECTION 7 — ACCOUNTS POISED FOR GROWTH
--
--  Composite "Growth Readiness Score" (0–100) built from:
--    • Engagement score  (40 pts): logins + features adopted
--    • Health score      (30 pts): NPS + low support tickets
--    • Expansion signal  (20 pts): active expansion conversations
--    • Timing score      (10 pts): contract renewal window (sweet spot = 90-270 days out)
--
--  Tier:
--    80–100 = 🔥 High Priority
--    60–79  = ✅ Strong Candidate
--    40–59  = 🔍 Monitor Closely
--    <40    = ⚠️  At Risk / Not Ready
-- =============================================================

growth_score_raw AS (
    SELECT
        aa.account_id,
        ac.name,
        ac.industry,
        ac.segment,
        ac.arr,
        ac.mrr,
        ac.csm_owner,
        aa.logins_last_90d,
        aa.features_adopted,
        aa.support_tickets_open,
        aa.nps_score,
        aa.expansion_convos,
        aa.days_since_last_qbr,
        aa.contract_days_remaining,

        -- ENGAGEMENT SCORE (40 pts max)
        -- Logins: 0-210+ normalized to 20 pts
        -- Features adopted: 0-15 normalized to 20 pts
        LEAST(ROUND(aa.logins_last_90d::NUMERIC / 210 * 20, 1), 20.0)
        + LEAST(ROUND(aa.features_adopted::NUMERIC / 15 * 20, 1), 20.0)
            AS engagement_score,

        -- HEALTH SCORE (30 pts max)
        -- NPS: 0-100 normalized to 20 pts
        -- Support tickets: 0 tickets = 10 pts, penalty -2 per open ticket
        ROUND(aa.nps_score::NUMERIC / 100 * 20, 1)
        + GREATEST(10 - (aa.support_tickets_open * 2), 0)
            AS health_score,

        -- EXPANSION SIGNAL SCORE (20 pts max)
        -- 1 active expansion convo = 10 pts, 2+ = 20 pts
        LEAST(aa.expansion_convos * 10, 20)
            AS expansion_score,

        -- TIMING SCORE (10 pts max)
        -- Sweet spot: renewal in 90-270 days
        CASE
            WHEN aa.contract_days_remaining BETWEEN 90 AND 270 THEN 10
            WHEN aa.contract_days_remaining BETWEEN 30  AND 89  THEN  6
            WHEN aa.contract_days_remaining BETWEEN 271 AND 365 THEN  4
            ELSE 2
        END AS timing_score

    FROM account_activity aa
    JOIN accounts ac ON aa.account_id = ac.account_id
    WHERE ac.status = 'active'
),

growth_readiness AS (
    SELECT
        account_id,
        name,
        industry,
        segment,
        arr,
        mrr,
        csm_owner,
        logins_last_90d,
        features_adopted,
        nps_score,
        expansion_convos,
        contract_days_remaining,

        engagement_score,
        health_score,
        expansion_score,
        timing_score,

        -- Composite score
        ROUND(engagement_score + health_score + expansion_score + timing_score, 1)
            AS growth_readiness_score,

        -- Tier classification
        CASE
            WHEN ROUND(engagement_score + health_score + expansion_score + timing_score, 1) >= 80
                THEN '🔥 High Priority'
            WHEN ROUND(engagement_score + health_score + expansion_score + timing_score, 1) >= 60
                THEN '✅ Strong Candidate'
            WHEN ROUND(engagement_score + health_score + expansion_score + timing_score, 1) >= 40
                THEN '🔍 Monitor Closely'
            ELSE '⚠️  At Risk / Not Ready'
        END AS growth_tier,

        RANK() OVER (
            ORDER BY ROUND(engagement_score + health_score + expansion_score + timing_score, 1) DESC
        ) AS growth_rank

    FROM growth_score_raw
)


