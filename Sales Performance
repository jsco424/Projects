-- ── 1. YoY Growth ───────────────────────────────────────────
SELECT '=== YEAR-OVER-YEAR GROWTH ===' AS section, NULL::TEXT AS col2, NULL::TEXT AS col3,
       NULL::TEXT AS col4, NULL::TEXT AS col5, NULL::TEXT AS col6
UNION ALL
SELECT
    period_label        AS period,
    current_year::TEXT,
    current_revenue::TEXT,
    prior_year_revenue::TEXT,
    yoy_revenue_delta::TEXT,
    yoy_growth_pct::TEXT || '%' AS yoy_growth
FROM (
    SELECT
        TO_CHAR(period, 'YYYY-Mon') AS period_label,
        current_year,
        current_revenue,
        prior_year_revenue,
        yoy_revenue_delta,
        yoy_growth_pct
    FROM yoy_growth
) x

UNION ALL SELECT '---',NULL,NULL,NULL,NULL,NULL

