    period_label,
    mql::TEXT || ' MQL → ' || closed_won::TEXT || ' Won',
    overall_win_rate_pct::TEXT || '% overall win rate',
    oppty_to_won_pct::TEXT || '% oppty→won',
    decision_win_rate_pct::TEXT || '% decision win rate',
    NULL
FROM funnel_metrics

UNION ALL SELECT '---',NULL,NULL,NULL,NULL,NULL

-- ── 7. Accounts Poised for Growth ───────────────────────────
UNION ALL
SELECT '=== ACCOUNTS POISED FOR GROWTH ===',NULL,NULL,NULL,NULL,NULL
UNION ALL
SELECT
    name,
    industry,
    arr::TEXT,
    growth_readiness_score::TEXT || ' / 100',
    growth_tier,
    csm_owner
FROM growth_readiness
ORDER BY
    CASE section
        WHEN '=== YEAR-OVER-YEAR GROWTH ==='             THEN 1
        WHEN '=== MONTH-OVER-MONTH GROWTH ==='           THEN 2
        WHEN '=== QUARTER-OVER-QUARTER GROWTH ==='       THEN 3
        WHEN '=== CHURN METRICS ==='                     THEN 4
        WHEN '=== TOP INDUSTRIES BY ACTIVE ARR ==='      THEN 5
        WHEN '=== MARKETING FUNNEL DISTRIBUTION ==='     THEN 6
        WHEN '=== ACCOUNTS POISED FOR GROWTH ==='        THEN 7
        ELSE 99
    END;


